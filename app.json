{
  "expo": {
    "name": "DoseDay",
    "slug": "doseday",
    "version": "5.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "doseday",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050B12"
    },
    "ios": {
      "bundleIdentifier": "com.doseday.premium",
      "supportsTablet": false,
      "buildNumber": "14",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSHealthShareUsageDescription": "DoseDay lê peso e atividade do Apple Saúde para ajudar a entender seu tratamento.",
        "NSHealthUpdateUsageDescription": "DoseDay pode salvar peso e doses no Apple Saúde se você autorizar.",
        "NSMicrophoneUsageDescription": "DoseDay grava perguntas para sua consulta apenas se você autorizar (feature opcional).",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#5BA8D9",
          "sounds": []
        }
      ],
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.553630899758-j2n0e39169d0tuvoncjd4131gtoq3qd5"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": "5.0.0",
    "web": {
      "bundler": "metro"
    },
    "android": {
      "package": "com.doseday.premium"
    }
  }
}
